# Fabric Workspace
FABRIC_WORKSPACE_NAME=FabLab_SQL_Endpoint
FABRIC_LAKEHOUSE_NAME=LH_01
FABRIC_WAREHOUSE_NAME=WH_01

# Fabric Capacity (for cold-cache pause/resume)
# Fabric capacity GUID — get from: az rest --method get --resource https://api.fabric.microsoft.com --url https://api.fabric.microsoft.com/v1/capacities
FABRIC_CAPACITY_ID=
# ARM resource details — needed for resume/suspend via management.azure.com
FABRIC_CAPACITY_NAME=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# SQL Endpoints (fill in after running provision/setup_fabric.py)
LAKEHOUSE_SERVER=
LAKEHOUSE_DATABASE=
WAREHOUSE_SERVER=
WAREHOUSE_DATABASE=

# Azure / Entra ID
TENANT_ID=

# Optional: override ODBC driver name
# ODBC_DRIVER=ODBC Driver 18 for SQL Server
